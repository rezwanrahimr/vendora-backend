generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VENDOR
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OfferType {
  BOGO
  DISCOUNT
  SPECIAL
}

enum OfferStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DELETED
}

model User {
  id                     Int                @id @default(autoincrement())
  email                  String             @unique
  password               String
  name                   String?
  phone                  String?            @unique
  location               String?
  dateOfBirth            DateTime?
  role                   UserRole           @default(USER)
  status                 UserStatus         @default(PENDING)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  isEmailVerified        Boolean            @default(false)
  vendorProfile          VendorProfile?
  notifications          UserNotification[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model UserNotification {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newOffer        Boolean  @default(true)
  renewalReminder Boolean  @default(true)
  promotional     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VendorProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId      String   @default(uuid())
  city          String
  streetAddress String
  zipCode       String
  logoUrl       String?
  businessName  String?
  contactEmail  String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  offers        Offer[]
}



model Offer {
  id             String        @id @default(uuid())
  title          String
  description    String
  type           OfferType // current its only 3 types, but later it may have to  extract to separate model if needed
  status         OfferStatus   @default(ACTIVE)
  isReusable     Boolean       @default(false)
  maxRedemptions Int?
  redeemedCount  Int           @default(0)
  validFrom      DateTime      @default(now())
  validUntil     DateTime
  metadata       Json?
  vendorId       Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  vendor         VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

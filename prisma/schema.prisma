generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  name                   String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  password               String
  role                   UserRole               @default(USER)
  dateOfBirth            DateTime?
  location               String?
  imageUrl               String?
  phone                  String?                @unique
  status                 UserStatus             @default(PENDING)
  isEmailVerified        Boolean                @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  fcmTokens              Json?
  lastActiveAt           DateTime?
  isDeleted              Boolean                @default(false)
  notifications          UserNotification[]
  vendorProfile          VendorProfile?
  offerRedemptions       OfferRedemption[]
  offerRedemptionEvents  OfferRedemptionEvent[]
  pushNotifications      PushNotification[]
  qrcodes                QRCode[]
}

model UserNotification {
  id              String   @id @default(uuid())
  userId          String
  newOffer        Boolean  @default(true)
  renewalReminder Boolean  @default(true)
  promotional     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id             String          @id @default(uuid())
  name           String
  icon           String?
  vendorProfiles VendorProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  businessName  String?
  about         String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  city          String
  contactEmail  String?
  logoUrl       String?
  streetAddress String
  vendorId      String   @default(uuid())
  isDeleted     Boolean  @default(false)
  zipCode       String
  categoryId    String
  Category      Category @relation(fields: [categoryId], references: [id])
  offers        Offer[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Offer {
  id                    String                 @id @default(uuid())
  title                 String
  description           String
  type                  OfferType
  status                OfferStatus            @default(ACTIVE)
  isReusable            Boolean                @default(false)
  maxRedemptions        Int?
  redeemedCount         Int                    @default(0)
  validFrom             DateTime               @default(now())
  validUntil            DateTime
  vendorId              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  metadata              Json?
  estimatedValue        Int                    @default(0)
  termsAndConditions    String?
  isDeleted             Boolean                @default(false)
  cooldownPeriod        Int?
  thumbnail             String?                @default("")
  VendorProfile         VendorProfile          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  offerRedemptions      OfferRedemption[]
  offerRedemptionEvents OfferRedemptionEvent[]
  qrcodes               QRCode[]
}

model OfferRedemption {
  id             String   @id @default(uuid())
  userId         String
  offerId        String
  lastRedeemedAt DateTime @default(now())
  createdAt      DateTime @default(now())

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, userId]) // each user can have only one redemption record per offer
  @@index([offerId, userId])
}

model OfferRedemptionEvent {
  id         String   @id @default(uuid())
  offerId    String
  userId     String
  vendorId   String
  redeemedAt DateTime @default(now())

  Offer Offer @relation(fields: [offerId], references: [id])
  User  User  @relation(fields: [userId], references: [id])

  @@index([vendorId, redeemedAt])
  @@index([offerId, redeemedAt])
}

model PushNotification {
  id        String             @id @default(uuid())
  userId    String
  title     String
  body      String
  data      Json?
  type      NotificationType
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
}

model AdminLegal {
  id                 String @id @default("ADMIN_LEGAL_SINGLETON_ID")
  TermsAndConditions String
  PrivacyPolicy      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminNotification {
  id                           String  @id @default("ADMIN_NOTIFICATION_SINGLETON_ID")
  enablePushNotifications      Boolean @default(true)
  newOfferNotifications        Boolean @default(true)
  expiryOfferNotifications     Boolean @default(true)
  subscriptionRenewalReminders Boolean @default(true)
  enableEmailNotifications     Boolean @default(true)
  weeklyDigest                 Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminGeneralSettings {
  id                        String  @id @default("ADMIN_GENERAL_SETTINGS_SINGLETON_ID")
  defaultLanguage           String? @default("en")
  isUnderMaintenance        Boolean @default(false)
  isAutoApproveForVendorOn  Boolean @default(false)
  isNewVendorRegistrationOn Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QRCode {
  id         String    @id @default(uuid())
  userId     String
  offerId    String
  isRedeemed Boolean   @default(false)
  token      String    @unique
  redeemedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model AppHeroSlider {
  id        String   @id @default(uuid())
  imageUrl  String
  isActive  Boolean  @default(false)
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum NotificationType {
  NEW_OFFER
  RENEWAL_REMINDER
  PROMOTIONAL
  VENDOR_APPROVED
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum UserRole {
  ADMIN
  VENDOR
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  REJECTED
}

enum OfferStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DELETED
}

enum OfferType {
  BOGO
  DISCOUNT
  SPECIAL
}

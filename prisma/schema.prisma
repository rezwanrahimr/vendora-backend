generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String             @id @default(uuid())
  email                  String             @unique
  name                   String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  password               String
  role                   UserRole           @default(USER)
  dateOfBirth            DateTime?
  location               String?
  imageUrl               String?
  phone                  String?            @unique
  status                 UserStatus         @default(PENDING)
  isEmailVerified        Boolean            @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  notifications          UserNotification[]
  vendorProfile          VendorProfile?
  offerRedemptions       OfferRedemption[]
}

model UserNotification {
  id              String   @id @default(uuid())
  userId          String
  newOffer        Boolean  @default(true)
  renewalReminder Boolean  @default(true)
  promotional     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VendorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  businessName  String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  city          String
  contactEmail  String?
  logoUrl       String?
  streetAddress String
  vendorId      String   @default(uuid())
  zipCode       String
  offers        Offer[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Offer {
  id               String            @id @default(uuid())
  title            String
  description      String
  type             OfferType
  status           OfferStatus       @default(ACTIVE)
  isReusable       Boolean           @default(false)
  maxRedemptions   Int?
  redeemedCount    Int               @default(0)
  validFrom        DateTime          @default(now())
  validUntil       DateTime
  vendorId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  metadata         Json?
  isDeleted        Boolean           @default(false)
  cooldownPeriod   Int? // in days
  VendorProfile    VendorProfile     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  offerRedemptions OfferRedemption[]
}

model OfferRedemption {
  id             String   @id @default(uuid())
  userId         String
  offerId        String
  lastRedeemedAt DateTime @default(now())
  createdAt      DateTime @default(now())

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, userId]) // each user can have only one redemption record per offer
  @@index([offerId, userId])
}

enum UserRole {
  ADMIN
  VENDOR
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OfferStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DELETED
}

enum OfferType {
  BOGO
  DISCOUNT
  SPECIAL
}
